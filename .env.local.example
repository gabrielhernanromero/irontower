# Google Analytics 4 — obtené tu ID en analytics.google.com
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# NextAuth — generá un secret con: openssl rand -base64 32
NEXTAUTH_SECRET=tu-secret-aleatorio-aqui
NEXTAUTH_URL=http://localhost:3001

# Credenciales del admin del blog
ADMIN_EMAIL=irontowerta@gmail.com
ADMIN_PASSWORD=tu-contraseña-segura

# Supabase — obtené estos valores en supabase.com > Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxx.supabase.co
